                                      height : ${n.bannerData.promoCodePlacementCoordMobile.height_percent+"%"};\n                                                     width : ${n.bannerData.promoCodePlacementCoordMobile.width_percent+"%"};"\n                                         >\n                                             ${n.bannerData.promoCode}\n                                         </div>`:""}\n                                </div>\n                            </a>\n                        </div>`:""}\n                </div>`,a}var GET_QNA_BANNER_UTILITIES={adBannerInfo:{},getQnaBanner:function(n){var e=JSON.parse(QNA_BANNER_INFO);if(e.length>0&&""!=e[0].project_id&&null!=e[0].project_id){var a=1==e[0].is_json_build||"1"==e[0].is_json_build?1:0,t=JSON.stringify({user_ip_address:n,user_grade:e[0].grade,user_concept:e[0].concept,user_board:e[0].board,user_subject:e[0].subject,project_id:e[0].project_id});jQuery.ajax({type:"POST",url:COMMON_UTILS_ENDPOINT_KEY+"wp/get-qna-banner",headers:{"Content-Type":"application/json"},data:t,success:function(n,e,t){if(200==t.status&&n.success&&n.qnaBanner.banner_json&&null!=n.qnaBanner.banner_json&&null!=n.qnaBanner.html_content){var o={},r=n.qnaBanner.user_location||{};o={bannerData:{...n.qnaBanner.banner_json,...n.qnaBanner.html_content},...r},GET_QNA_BANNER_UTILITIES.adBannerInfo=o;var c=a?createQnABannerJson(o):createQnABannerHtml(o);bannerHtml=jQuery.parseHTML(c),jQuery(".widget.top-banner-widget > a").replaceWith(bannerHtml)}},error:function(n){console.error(n)}})}}};
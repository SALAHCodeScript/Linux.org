d-size: 100% 8px;\n  border-radius: 0 0 16px 16px;\n  box-shadow: 0 2px 10px rgb(0 0 0 / 20%);\n  left: 50%;\n  list-style-type: none;\n  max-width: 800px;\n  padding: 12px;\n  position: absolute;\n  top: 100%;\n  transform: translate3d(-50%, 0, 0);\n  width: 100%;\n  z-index: -1;\n\n  a {\n    cursor: pointer;\n    display: block;\n    font-weight: 400;\n    padding: 18px 24px;\n\n    &:hover {\n      color: var(--aard-color-interactive-headline-hovered-ondefault);\n    }\n\n    &:active {\n      color: var(--aard-color-interactive-headline-active-ondefault);\n    }\n\n    svg {\n      margin-left: 8px;\n      width: 20px;\n    }\n  }\n}\n\n/* Mask the box shadow on the top, since card is “under” header shadow. */\n.nav-tab > .nav-tab-content::before {\n  background: #fff;\n  content: '';\n  display: block;\n  height: 8px;\n  left: 0;\n  position: absolute;\n  top: 0;\n  translate: -1% -100%;\n  width: 102%;\n}\n\n.trademark {\n  font-size: 8px;\n  vertical-align: super;\n}\n\n@media (min-width: 768px) {\n  .root {\n    display: flex;\n    padding: 0 0 24px;\n  }\n}\n\n@media (min-width: 1024px) {\n  .root {\n    padding-bottom: 30px;\n  }\n\n  .nav-tab {\n    &:last-of-type a {\n      padding-right: 0;\n    }\n\n    > a::after {\n      height: 52px;\n    }\n  }\n\n  .nav-tab-content {\n    top: 100%;\n  }\n}\n"],sourceRoot:""}]),a.locals={root:"PagesMenu-module_root_a677ab9c88dcee8b3a08","nav-tab":"PagesMenu-module_nav-tab_f4fbd041f275bcffb0d9","is-open":"PagesMenu-module_is-open_a3d4ef7641437d209e1d","nav-tab-content":"PagesMenu-module_nav-tab-content_c2464af0e73b19227402",trademark:"PagesMenu-module_trademark_bf2ad1043248bff41364"},e.exports=a},56650:(e,n,o)=>{var t=o(87537),a=o(23645)(t);a.push([e.id,'.Search-module_root_b97aa507464d1059ac39{--magnify-icon-button-size: 48px;align-items:center;display:flex;flex-direction:row;justify-content:center;margin:0;position:relative;width:100%}.dictionary-site .Search-module_root_b97aa507464d1059ac39{--focus-active-outli
  &.open {\n    left: 0;\n  }\n}\n\n.close-button {\n  align-self: flex-end;\n  background: none;\n  border: none;\n  color: var(--lightgray);\n  font-size: 24px;\n  margin: 18px 10px;\n}\n\n.drawer-container > ul {\n  display: flex;\n  flex-direction: column;\n  margin: 0;\n  padding: 0;\n}\n\n.menu-item-top {\n  color: var(--lightgray);\n  list-style: none;\n\n  &.separator::before {\n    border-top: 1px solid #cac4d0;\n    content: '';\n    display: block;\n    margin: 8px 0;\n  }\n}\n\n.menu-item-top-toggle {\n  align-items: center;\n  display: flex;\n  line-height: 16px;\n\n  &.has-submenu {\n    border-radius: 32px;\n    color: var(--aard-color-ink-default);\n    cursor: pointer;\n    font: bold 18px LFTEtica, sans-serif;\n    justify-content: space-between;\n    letter-spacing: 0.2px;\n    line-height: 20px;\n    padding: 16px 28px 16px 16px;\n\n    &:active {\n      background-color: var(--softgray);\n      font-weight: 700;\n    }\n  }\n\n  & > a {\n    border-radius: 32px;\n    color: var(--lightgray);\n    display: block;\n    font-size: 14px;\n    font-weight: normal;\n    height: 100%;\n    margin: 0;\n    padding: 16px;\n    text-decoration: none;\n    width: 100%;\n\n    &:active {\n      background-color: var(--softgray);\n      font-weight: 700;\n    }\n  }\n}\n\n.menu-items-container {\n  height: 0;\n  overflow: hidden;\n  padding-left: 8px;\n}\n\n.expanded {\n  height: initial;\n  overflow: initial;\n}\n\n.menu-link {\n  list-style: none;\n}\n\n.menu-link a {\n  border-radius: 32px;\n  color: var(--lightgray);\n  display: block;\n  font-size: 14px;\n  padding: 16px;\n  text-decoration: none;\n  width: 100%;\n\n  &:active {\n    background-color: var(--softgray);\n    font-weight: 700;\n  }\n}\n\n.menu-link sup {\n  font-size: 8px;\n  vertical-align: super;\n}\n\n.account-icon {\n  font-size: 16px;\n  margin-right: 12px;\n}\n\n.drawer-underlay {\n  background-color: transparent;\n  display: none;\n  height: 100%;\n  left: 0;\n  position: fixed;\n  
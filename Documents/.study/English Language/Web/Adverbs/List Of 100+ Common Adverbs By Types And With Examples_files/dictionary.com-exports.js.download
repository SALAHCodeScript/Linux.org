\n  cursor: pointer;\n  display: flex;\n  font-size: 16px;\n  justify-content: space-between;\n  outline-color: var(--dictionaryblue);\n  padding: 16px;\n  width: 100%;\n\n  &.category-error {\n    border-color: var(--error);\n  }\n\n  &.error {\n    border-color: var(--error);\n  }\n\n  p {\n    color: var(--lightgraytext);\n    font-size: 16px;\n    margin: 0;\n    padding: 16px;\n  }\n}\n\n.character-count {\n  bottom: 16px;\n  position: absolute;\n  right: 19px;\n}\n\n.checkmark::selection {\n  transform: scale(1);\n}\n\n.color-container {\n  display: flex;\n\n  input {\n    cursor: pointer;\n    opacity: 0;\n    outline: unset;\n    position: absolute;\n  }\n\n  label {\n    border-radius: 50%;\n    height: 32px;\n    margin-right: 12px;\n    width: 32px;\n\n    &:focus-within {\n      outline: 2px solid -webkit-focus-ring-color;\n    }\n  }\n\n  svg {\n    color: #fff;\n    height: 22px;\n    left: 5px;\n    opacity: 0;\n    position: relative;\n    top: 5px;\n    transform: scale(0.5);\n    transition: all 350ms cubic-bezier(0.175, 0.885, 0.32, 1.275);\n    width: 22px;\n\n    &[data-selected='true'] {\n      opacity: 1;\n      transform: scale(1);\n    }\n  }\n}\n\n.color-label {\n  label {\n    color: black;\n    cursor: pointer;\n    display: inline-block;\n    font-size: 14px;\n    margin-bottom: 16px;\n    text-transform: uppercase;\n  }\n}\n\n.dropdown {\n  background-color: #fff;\n  border: 2px solid var(--faintgray);\n  border-radius: 8px;\n  flex-direction: column;\n  height: auto;\n  left: 0;\n  overflow-y: auto;\n  position: absolute;\n  top: calc(100% + 8px);\n  width: 100%;\n  z-index: 10;\n\n  > div {\n    cursor: pointer;\n    flex: 1 1 0%;\n    font-size: 16px;\n    line-height: 28px;\n    padding: 4px 16px;\n    transition: all 300ms ease;\n\n    &:hover {\n      background-color: var(--faintgray);\n    }\n  }\n}\n\n.error-container {\n  display: flex;\n  margin: 4px 0;\n  position: absolute;\n\n  p {\n    display: inline;\n    font-size: 14px;\n    line-height: 1;\n    margin: auto;\n  }\n\n  svg {\n    color: var(--error);\n    height: 20px;\n    margin-right: 4px;\n    width: 20px;\n  }\n}\n\n.description {\n  align-items: flex-start;\n  height: 140px;\n}\n\n.color-heading {\n  align-items: center;\n  display: flex;\n  margin-bottom: 16px;\n\n  label {\n    margin-bottom: 0;\n  }\n\n  svg {\n    color: var(--dictionaryblue);\n    height: 20px;\n    margin-left: 8px;\n    width: 20px;\n  }\n}\n\n.icon {\n  font-family: dictionary-fonticon;\n  font-size: 24px;\n  margin: 0;\n\n  &::before {\n    content: var(--icon-downArrow);\n  }\n}\n\n.input-container {\n  margin-bottom: 28px;\n  position: relative;\n\n  &:last-of-type {\n    margin-bottom: 8px;\n  }\n}\n\n.input-field {\n  border: 2px solid var(--mildgray);\n  color: var(--lightgraytext);\n  display: flex;\n  flex: 1 1 0%;\n  font-size: 16px;\n  padding: 16px;\n  position: relative;\n  width: 100%;\n\n  &.error {\n    border-color: var(--error);\n  }\n\n  &:focus-within {\n    border-color: var(--dictionaryblue);\n  }\n}\n\n.name-error {\n  border-color: var(--error);\n}\n\n.submit-button {\n  background-color: var(--dictionaryblue);\n  border: none;\n  border-radius: 100px;\n  color: var(--faintgray);\n  cursor: pointer;\n  font-size: 16px;\n  font-weight: bold;\n  line-height: 1;\n  padding: 16px 40px;\n  position: relative;\n  transition: all 0.25s ease-in-out 0s;\n  width: 100%;\n\n  &:hover {\n    transform: scale(1.05);\n  }\n\n  &:active {\n    transform: scale(1);\n  }\n}\n\n.tooltip-content {\n  width: 250px;\n}\n"],sourceRoot:""}]),a.locals={root:"WordListForm-module_root_a048eaee194d47e8d600",category:"WordListForm-module_category_d00d1332408d05395a2f","category-error":"WordListForm-module_category-error_e971e2d77d451112622a",error:"WordListForm-module_error_c70e133ed1232eec7d91","character-count":"WordListForm-module_character-count_daacf7e5f33eb870b9f3",checkmark:"WordListForm-module_checkmark_de6482bda8e4f077d9e4","color-container":"W